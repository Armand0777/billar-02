# Copia este archivo a .env.local y completa los valores
# NUNCA subas .env.local al repositorio

# URL del proyecto Supabase (visible en: Project Settings > API)
NEXT_PUBLIC_SUPABASE_URL=https://tu-proyecto.supabase.co

# Clave anon pública de Supabase (visible en: Project Settings > API)
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Clave de servicio (PRIVADA, solo en el servidor) (visible en: Project Settings > API)
# NUNCA usar NEXT_PUBLIC_ con esta clave
SUPABASE_SERVICE_ROLE_KEY=eyJ...
